{
  "name": "@faremeter/middleware-openapi",
  "version": "0.19.0",
  "description": "OpenAPI pricing engine for faremeter middleware",
  "keywords": [
    "faremeter",
    "typescript",
    "openapi",
    "pricing"
  ],
  "license": "LGPL-3.0-only",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/src/index.js",
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./expr": {
      "require": "./dist/src/expr.js",
      "import": "./dist/src/expr.js",
      "types": "./dist/src/expr.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@tapjs/tsx": "catalog:",
    "@types/web": "catalog:",
    "@typescript/lib-dom": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tap": "catalog:",
    "tsc-esm-fix": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "typescript-language-server": "catalog:"
  },
  "dependencies": {
    "@faremeter/logs": "workspace:^",
    "@faremeter/middleware": "workspace:^",
    "@faremeter/types": "workspace:^",
    "@scalar/json-magic": "catalog:",
    "@scalar/openapi-parser": "catalog:",
    "arktype": "catalog:",
    "expr-eval": "catalog:",
    "json-p3": "catalog:"
  },
  "tap": {
    "plugin": [
      "!@tapjs/typescript",
      "@tapjs/tsx"
    ]
  }
}
